// ================= CONTINUAÇÃO DO SCRIPT =================

function updateCategories(){
    let cats = [...new Set(prompts.map(p => p.category))];
    categorySelect.innerHTML = '<option value="">Todas categorias</option>';
    cats.forEach(cat => {
        categorySelect.innerHTML += `<option value="${cat}">${cat}</option>`;
    });
}

function copy(index, btn) {
    const text = prompts[index].prompt;
    navigator.clipboard.writeText(text).then(() => {
        const originalText = btn.innerText;
        btn.innerText = "Copiado! ✅";
        btn.classList.replace('bg-blue-600', 'bg-green-600');
        setTimeout(() => {
            btn.innerText = originalText;
            btn.classList.replace('bg-green-600', 'bg-blue-600');
        }, 2000);
    });
}

function toggleFav(index) {
    prompts[index].fav = !prompts[index].fav;
    save();
    render();
}

function deleteItem(index) {
    if(confirm("Deseja excluir este prompt?")) {
        prompts.splice(index, 1);
        save();
        render();
    }
}

// Escutadores de eventos para busca e filtro
search.addEventListener('input', render);
categorySelect.addEventListener('change', render);

// Inicialização
render();

// Função para simular a criação com IA (Passo 1 do seu plano)
function generatePromptAI() {
    const nome = prompt("Para qual profissão ou tarefa deseja criar um prompt?");
    if(nome) {
        // Aqui você pode integrar uma chamada de API no futuro
        // Por enquanto, ele cria um card estruturado automaticamente
        const novo = {
            name: nome,
            category: "IA Gerada",
            description: "Prompt otimizado por IA",
            prompt: `Aja como um especialista em ${nome}. Sua tarefa é realizar...`
        };
        prompts.push(novo);
        save();
        render();
    }
}
</script>
</body>
</html>
